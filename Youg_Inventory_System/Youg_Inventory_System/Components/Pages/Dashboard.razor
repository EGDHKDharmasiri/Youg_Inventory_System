@page "/"
@using Youg_Inventory_System.Data
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@inject AppDbContext DbContext
@rendermode InteractiveServer

<PageTitle>Dashboard - Young Inventory System</PageTitle>

<div class="dashboard-header p-4 bg-white border-bottom shadow-sm rounded-3 mb-4">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h2 class="mb-1 fw-bold">Dashboard Overview</h2>
            <p class="text-muted mb-0">A quick look at your store's performance and recent activities.</p>
        </div>
    </div>
</div>

<div class="dashboard-body">
    <div class="row g-4 mb-4">
        <div class="col-lg-3 col-md-6">
            <div class="card border-0 shadow-sm h-100 stat-card">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="text-muted mb-2 small fw-semibold">Total Revenue</p>
                            <h3 class="mb-0 fw-bold">@FormatCurrency(dashboardStats.TotalRevenue)</h3>
                        </div>
                        <div class="p-3 rounded-circle icon-box bg-primary-light">
                            <i class="bi bi-currency-dollar text-primary fs-5"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-3 col-md-6">
            <div class="card border-0 shadow-sm h-100 stat-card">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="text-muted mb-2 small fw-semibold">Total Orders</p>
                            <h3 class="mb-0 fw-bold">@dashboardStats.TotalOrders</h3>
                        </div>
                        <div class="p-3 rounded-circle icon-box bg-warning-light">
                            <i class="bi bi-cart-check text-warning fs-5"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-3 col-md-6">
            <div class="card border-0 shadow-sm h-100 stat-card">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="text-muted mb-2 small fw-semibold">Active Customers</p>
                            <h3 class="mb-0 fw-bold">@dashboardStats.ActiveCustomers</h3>
                        </div>
                        <div class="p-3 rounded-circle icon-box bg-success-light">
                            <i class="bi bi-people-fill text-success fs-5"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-3 col-md-6">
            <div class="card border-0 shadow-sm h-100 stat-card">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="text-muted mb-2 small fw-semibold">Out-of-stock Items</p>
                            <h3 class="mb-0 fw-bold text-danger">@dashboardStats.OutOfStockItems</h3>
                        </div>
                        <div class="p-3 rounded-circle icon-box bg-danger-light">
                            <i class="bi bi-exclamation-circle-fill text-danger fs-5"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body p-4">
                    <h5 class="mb-4 fw-bold">Recent Orders</h5>
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <tbody>
                                @if (recentOrders.Any())
                                {
                                    @foreach (var order in recentOrders)
                                    {
                                        <tr>
                                            <td>
                                                <div class="d-flex align-items-center gap-2">                                             
                                                    <div>
                                                        <div class="fw-bold small">@order.CustomerName</div>
                                                        <div class="text-muted x-small">@order.OrderId</div>
                                                    </div>
                                                </div>
                                            </td>
                                            <td class="text-end fw-bold">@FormatCurrency(order.TotalAmount)</td>
                                            <td><span class="badge @GetOrderStatusBadge(order.Status)">@order.Status</span></td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr><td colspan="3" class="text-center text-muted py-4">No recent orders found.</td></tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body p-4">
                    <h5 class="mb-4 fw-bold">Best Sellers</h5>
                    <div class="d-flex flex-column gap-3">
                        @if (bestSellingProducts.Any())
                        {
                            @foreach (var product in bestSellingProducts)
                            {
                                <div class="d-flex align-items-center gap-3">
                                    <img src="@(string.IsNullOrEmpty(product.Image) ? "https://via.placeholder.com/45" : product.Image)" 
                                         class="rounded" width="45" height="45" alt="Product">
                                    <div class="flex-grow-1">
                                        <div class="fw-bold small">@product.Name</div>
                                        <div class="text-muted x-small">@product.Sales Sales</div>
                                    </div>
                                    <div class="fw-bold">@FormatCurrency(product.Price)</div>
                                </div>
                            }
                        }
                        else
                        {
                            <p class="text-center text-muted py-4">No sales data available yet.</p>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private DashboardStatsDto dashboardStats = new();
    private List<Order> recentOrders = new();
    private List<BestSellingProductDto> bestSellingProducts = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadDashboardData();
    }

    private async Task LoadDashboardData()
    {
        try
        {
            // Fetch real data from database
            dashboardStats.TotalRevenue = await DbContext.Orders
                .Where(o => o.Status == "Completed")
                .SumAsync(o => o.TotalAmount);

            dashboardStats.TotalOrders = await DbContext.Orders.CountAsync();

            dashboardStats.ActiveCustomers = await DbContext.Orders
                .Select(o => o.CustomerName)
                .Distinct()
                .CountAsync();

            dashboardStats.OutOfStockItems = await DbContext.Products
                .CountAsync(p => p.StockQuantity == 0);

            recentOrders = await DbContext.Orders
                .OrderByDescending(o => o.OrderDate)
                .Take(5)
                .ToListAsync();

            // Load top-selling products
            var products = await DbContext.Products
                .OrderByDescending(p => p.StockQuantity)
                .Take(5)
                .ToListAsync();

            bestSellingProducts = products
                .Select(p => new BestSellingProductDto
                {
                    Name = p.Name,
                    Price = p.Price,
                    Sales = 0,
                    Image = "https://via.placeholder.com/45"
                })
                .ToList();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading dashboard data: {ex.Message}");
        }
    }

    private string GetOrderStatusBadge(string status) => status switch
    {
        "Completed" => "bg-success",
        "Processing" => "bg-warning text-dark",
        "Cancelled" => "bg-danger",
        _ => "bg-secondary"
    };

    private string FormatCurrency(decimal amount)
    {
        return amount.ToString("N2", new System.Globalization.CultureInfo("en-LK"));
    }

    private class DashboardStatsDto
    {
        public decimal TotalRevenue { get; set; }
        public int TotalOrders { get; set; }
        public int ActiveCustomers { get; set; }
        public int OutOfStockItems { get; set; }
    }

    private class BestSellingProductDto
    {
        public string Name { get; set; } = "";
        public decimal Price { get; set; }
        public int Sales { get; set; }
        public string Image { get; set; } = "";
    }
}