@page "/orders"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@rendermode InteractiveServer
@inject AppDbContext DbContext
@inject IJSRuntime JS
@using Microsoft.EntityFrameworkCore

<PageTitle>Orders - Young Inventory System</PageTitle>

<div class="dashboard-header p-4 bg-white border-bottom shadow-sm rounded-3 mb-4">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h2 class="mb-1 fw-bold">Order Management</h2>
            <p class="text-muted mb-0">Track, manage and filter all customer orders in one place.</p>
        </div>
        <button class="btn btn-primary d-flex align-items-center gap-2" @onclick="OpenCreateModal">
            <i class="bi bi-plus-lg"></i> Create New Order
        </button>
    </div>
</div>

<div class="dashboard-body px-4">
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body p-3">
            <div class="row g-3">
                <div class="col-md-4">
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0 text-muted">
                            <i class="bi bi-search"></i>
                        </span>
                        <input type="text" class="form-control border-start-0" placeholder="Search by Order ID or Customer..." 
                               @bind="searchQuery" @bind:event="oninput" @onkeyup="ApplyFilters">
                    </div>
                </div>
                <div class="col-md-3">
                    <select class="form-select" @bind="selectedStatus">
                        <option value="">All Statuses</option>
                        <option value="Completed">Completed</option>
                        <option value="Processing">Processing</option>
                        <option value="Cancelled">Cancelled</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <input type="date" class="form-control" @bind="filterDate">
                </div>
                <div class="col-md-2">
                    <button class="btn btn-outline-secondary w-100" @onclick="ResetFilters">Reset Filters</button>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4 py-3">Order ID</th>
                            <th class="py-3">Customer</th>
                            <th class="py-3">Item</th>
                            <th class="py-3">Delivery</th>
                            <th class="py-3 text-end">Amount</th>
                            <th class="py-3 text-center">Status</th>
                            <th class="py-3 text-center pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (filteredOrders.Any())
                        {
                            @foreach (var order in filteredOrders)
                            {
                                <tr>
                                    <td class="ps-4 fw-bold text-primary">@order.OrderId</td>
                                    <td>
                                        <div>
                                            <span class="small fw-semibold">@order.CustomerName</span>
                                            <br />
                                            <small class="text-muted">@order.Phone1</small>
                                        </div>
                                    </td>
                                    <td class="small">@order.Item</td>
                                    <td class="small">
                                        <span class="badge @GetDeliveryBadge(order.DeliveryType)">@order.DeliveryType</span>
                                    </td>
                                    <td class="text-end fw-bold">Rs. @FormatCurrency(order.TotalAmount)</td>
                                    <td class="text-center">
                                        <span class="badge @GetStatusBadge(order.Status)">@order.Status</span>
                                    </td>
                                    <td class="text-center pe-4">
                                        <div class="btn-group">
                                            <button class="btn btn-sm btn-light border" title="View" @onclick="() => ViewOrder(order.Id)">
                                                <i class="bi bi-eye"></i>
                                            </button>
                                            <button class="btn btn-sm btn-light border" title="Edit" @onclick="() => EditOrder(order.Id)">
                                                <i class="bi bi-pencil"></i>
                                            </button>
                                            <button class="btn btn-sm btn-light border text-danger" title="Delete" @onclick="() => DeleteOrder(order.Id)">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" class="text-center text-muted py-4">
                                    No orders found. Create your first order!
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        <div class="card-footer bg-white py-3 border-0">
            <div class="d-flex justify-content-between align-items-center">
                <span class="small text-muted">Showing @filteredOrders.Count of @allOrders.Count orders</span>
            </div>
        </div>
    </div>
</div>

<!-- Create/Edit Order Modal -->
<div class="modal @(showModal ? "show d-block" : "fade")" id="createOrderModal" tabindex="-1" aria-labelledby="createOrderModalLabel" aria-hidden="@(!showModal)" style="@(showModal ? "background: rgba(0,0,0,0.5);" : "display: none;")">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0">
            <div class="modal-header bg-primary text-white border-0">
                <h5 class="modal-title" id="createOrderModalLabel">
                    @(isEditMode ? "Edit Order" : "Create New Order")
                </h5>
                <button type="button" class="btn-close btn-close-white" @onclick="CloseModal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="alert alert-danger alert-dismissible fade show mb-3" role="alert">
                        <i class="bi bi-exclamation-circle-fill me-2"></i>
                        @errorMessage
                        <button type="button" class="btn-close" @onclick="() => errorMessage = string.Empty"></button>
                    </div>
                }

                <form>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="customerName" class="form-label fw-semibold">Customer Name <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="customerName" placeholder="Enter customer name" 
                                   @bind="newOrder.CustomerName" />
                            @if (string.IsNullOrEmpty(newOrder.CustomerName))
                            {
                                <small class="text-danger">Customer name is required</small>
                            }
                        </div>

                        <div class="col-md-6 mb-3">
                            <label for="item" class="form-label fw-semibold">Product <span class="text-danger">*</span></label>
                            <select class="form-select" id="item" @bind="newOrder.Item">
                                <option value="">-- Select a Product --</option>
                                @foreach (var product in availableProducts)
                                {
                                    <option value="@product.Name">@product.Name - (Available: @product.StockQuantity)</option>
                                }
                            </select>
                            @if (string.IsNullOrEmpty(newOrder.Item))
                            {
                                <small class="text-danger">Product is required</small>
                            }
                        </div>

                        <div class="col-md-6 mb-3">
                            <label for="quantity" class="form-label fw-semibold">Quantity <span class="text-danger">*</span></label>
                            <input type="number" class="form-control" id="quantity" placeholder="1" min="1" 
                                   @bind="newOrder.Quantity" />
                            @if (newOrder.Quantity <= 0)
                            {
                                <small class="text-danger">Quantity must be at least 1</small>
                            }
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="phone1" class="form-label fw-semibold">Phone 1 <span class="text-danger">*</span></label>
                            <input type="tel" class="form-control" id="phone1" placeholder="+94XXXXXXXXX" 
                                   @bind="newOrder.Phone1" />
                            @if (string.IsNullOrEmpty(newOrder.Phone1))
                            {
                                <small class="text-danger">Primary phone is required</small>
                            }
                        </div>

                        <div class="col-md-6 mb-3">
                            <label for="phone2" class="form-label fw-semibold">Phone 2</label>
                            <input type="tel" class="form-control" id="phone2" placeholder="+94XXXXXXXXX (Optional)" 
                                   @bind="newOrder.Phone2" />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label for="address" class="form-label fw-semibold">Address <span class="text-danger">*</span></label>
                        <textarea class="form-control" id="address" placeholder="Enter delivery address" rows="3"
                                  @bind="newOrder.Address"></textarea>
                        @if (string.IsNullOrEmpty(newOrder.Address))
                        {
                            <small class="text-danger">Address is required</small>
                        }
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="deliveryType" class="form-label fw-semibold">Delivery Type <span class="text-danger">*</span></label>
                            <select class="form-select" id="deliveryType" @bind="newOrder.DeliveryType">
                                <option value="">Select Delivery Type</option>
                                <option value="COD">COD (Cash on Delivery)</option>
                                <option value="Online Transfer">Online Transfer</option>
                            </select>
                            @if (string.IsNullOrEmpty(newOrder.DeliveryType))
                            {
                                <small class="text-danger">Delivery type is required</small>
                            }
                        </div>

                        <div class="col-md-6 mb-3">
                            <label for="totalAmount" class="form-label fw-semibold">Total Amount (Rs.) <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <span class="input-group-text bg-light">Rs.</span>
                                <input type="number" class="form-control" id="totalAmount" placeholder="0.00" step="0.01" 
                                       @bind="newOrder.TotalAmount" />
                            </div>
                            @if (newOrder.TotalAmount <= 0)
                            {
                                <small class="text-danger">Amount must be greater than 0</small>
                            }
                        </div>
                    </div>

                    <div class="mb-3">
                        <label for="status" class="form-label fw-semibold">Status <span class="text-danger">*</span></label>
                        <select class="form-select" id="status" @bind="newOrder.Status">
                            <option value="">Select Status</option>
                            <option value="Processing">Processing</option>
                            <option value="Completed">Completed</option>
                            <option value="Cancelled">Cancelled</option>
                        </select>
                        @if (string.IsNullOrEmpty(newOrder.Status))
                        {
                            <small class="text-danger">Status is required</small>
                        }
                    </div>
                </form>
            </div>
            <div class="modal-footer bg-light border-0">
                <button type="button" class="btn btn-secondary" @onclick="CloseModal">Cancel</button>
                <button type="button" class="btn btn-primary" @onclick="SaveOrder">
                    @(isEditMode ? "Update Order" : "Create Order")
                </button>
            </div>
        </div>
    </div>
</div>

@code {
    private List<Order> allOrders = new();
    private List<Order> filteredOrders = new();
    private List<Product> availableProducts = new();
    private Order newOrder = new();
    private string searchQuery = "";
    private string selectedStatus = "";
    private DateTime? filterDate = null;
    private bool isEditMode = false;
    private int editingOrderId = 0;
    private string errorMessage = "";
    private bool showModal = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadOrders();
        await LoadProducts();
    }

    private async Task LoadOrders()
    {
        try
        {
            allOrders = await DbContext.Orders
                .OrderByDescending(o => o.OrderDate)
                .ToListAsync();

            filteredOrders = new List<Order>(allOrders);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading orders: {ex.Message}");
        }
    }

    private async Task LoadProducts()
    {
        try
        {
            availableProducts = await DbContext.Products
                .OrderBy(p => p.Name)
                .ToListAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading products: {ex.Message}");
        }
    }

    private void OpenCreateModal()
    {
        isEditMode = false;
        newOrder = new Order { Status = "Processing", Quantity = 1 };
        editingOrderId = 0;
        errorMessage = "";
        showModal = true;
    }

    private void CloseModal()
    {
        newOrder = new Order();
        isEditMode = false;
        errorMessage = "";
        showModal = false;
    }

    private async Task SaveOrder()
    {
        errorMessage = "";

        // Validate form fields
        if (string.IsNullOrEmpty(newOrder.CustomerName) || string.IsNullOrEmpty(newOrder.Item) ||
            string.IsNullOrEmpty(newOrder.Phone1) || string.IsNullOrEmpty(newOrder.Address) ||
            string.IsNullOrEmpty(newOrder.DeliveryType) || newOrder.TotalAmount <= 0 || 
            string.IsNullOrEmpty(newOrder.Status) || newOrder.Quantity <= 0)
        {
            errorMessage = "Please fill in all required fields with valid values.";
            return;
        }

        try
        {
            // Find the selected product
            var selectedProduct = availableProducts.FirstOrDefault(p => p.Name == newOrder.Item);
            if (selectedProduct == null)
            {
                errorMessage = "Selected product not found.";
                return;
            }

            // Validate quantity against available stock
            if (newOrder.Quantity > selectedProduct.StockQuantity)
            {
                errorMessage = $"Insufficient stock. Only {selectedProduct.StockQuantity} units available.";
                return;
            }

            if (isEditMode)
            {
                var existingOrder = await DbContext.Orders.FindAsync(editingOrderId);
                if (existingOrder != null)
                {
                    existingOrder.CustomerName = newOrder.CustomerName;
                    existingOrder.Address = newOrder.Address;
                    existingOrder.Item = newOrder.Item;
                    existingOrder.Quantity = newOrder.Quantity;
                    existingOrder.Phone1 = newOrder.Phone1;
                    existingOrder.Phone2 = newOrder.Phone2;
                    existingOrder.DeliveryType = newOrder.DeliveryType;
                    existingOrder.TotalAmount = newOrder.TotalAmount;
                    existingOrder.Status = newOrder.Status;
                    DbContext.Orders.Update(existingOrder);
                }
            }
            else
            {
                newOrder.OrderId = GenerateOrderId();
                newOrder.OrderDate = DateTime.Now;
                await DbContext.Orders.AddAsync(newOrder);

                // Deduct the quantity from product stock
                selectedProduct.StockQuantity -= newOrder.Quantity;
                DbContext.Products.Update(selectedProduct);
            }

            await DbContext.SaveChangesAsync();
            await LoadOrders();
            await LoadProducts();
            CloseModal();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error saving order: {ex.Message}";
            Console.WriteLine($"Error saving order: {ex}");
        }
    }

    private async Task EditOrder(int orderId)
    {
        var order = await DbContext.Orders.FindAsync(orderId);
        if (order != null)
        {
            isEditMode = true;
            editingOrderId = orderId;
            newOrder = new Order
            {
                CustomerName = order.CustomerName,
                Address = order.Address,
                Item = order.Item,
                Quantity = order.Quantity,
                Phone1 = order.Phone1,
                Phone2 = order.Phone2,
                DeliveryType = order.DeliveryType,
                TotalAmount = order.TotalAmount,
                Status = order.Status
            };
            errorMessage = "";
            showModal = true;
        }
    }

    private async Task ViewOrder(int orderId)
    {
        var order = await DbContext.Orders.FindAsync(orderId);
        if (order != null)
        {
            await EditOrder(orderId);
        }
    }

    private async Task DeleteOrder(int orderId)
    {
        try
        {
            var order = await DbContext.Orders.FindAsync(orderId);
            if (order != null)
            {
                DbContext.Orders.Remove(order);
                await DbContext.SaveChangesAsync();
                await LoadOrders();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error deleting order: {ex.Message}");
        }
    }

    private void ApplyFilters()
    {
        filteredOrders = allOrders
            .Where(o =>
            {
                bool matchesSearch = string.IsNullOrEmpty(searchQuery) ||
                    o.OrderId.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ||
                    o.CustomerName.Contains(searchQuery, StringComparison.OrdinalIgnoreCase);

                bool matchesStatus = string.IsNullOrEmpty(selectedStatus) ||
                    o.Status == selectedStatus;

                bool matchesDate = !filterDate.HasValue ||
                    o.OrderDate.Date == filterDate.Value.Date;

                return matchesSearch && matchesStatus && matchesDate;
            })
            .ToList();
    }

    private void ResetFilters()
    {
        searchQuery = "";
        selectedStatus = "";
        filterDate = null;
        filteredOrders = new List<Order>(allOrders);
        StateHasChanged();
    }

    private string GetStatusBadge(string status) => status switch
    {
        "Completed" => "bg-success-subtle text-success border border-success",
        "Processing" => "bg-warning-subtle text-warning-emphasis border border-warning",
        "Cancelled" => "bg-danger-subtle text-danger border border-danger",
        _ => "bg-secondary-subtle text-secondary border border-secondary"
    };

    private string GetDeliveryBadge(string delivery) => delivery switch
    {
        "COD" => "bg-info-subtle text-info border border-info",
        "Online Transfer" => "bg-success-subtle text-success border border-success",
        _ => "bg-secondary-subtle text-secondary border border-secondary"
    };

    private string GenerateOrderId()
    {
        var count = allOrders.Count + 1;
        return $"ORD-{DateTime.Now.Year}-{count:D3}";
    }

    private string FormatCurrency(decimal amount)
    {
        return amount.ToString("N2", new System.Globalization.CultureInfo("en-LK"));
    }
}