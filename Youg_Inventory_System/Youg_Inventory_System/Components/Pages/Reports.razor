@page "/reports"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@rendermode InteractiveServer
@inject AppDbContext DbContext
@inject IJSRuntime JS
@using Microsoft.EntityFrameworkCore
@using Youg_Inventory_System.Data
@using Youg_Inventory_System.Models

<PageTitle>Reports - Young Inventory System</PageTitle>

<style>
    @@media print {
        .modern-sidebar, .dashboard-header, .nav-tabs, .filter-section, 
        .print-hide-btn, #reportsTabs, .btn-group-controls {
            display: none !important;
        }

        .tab-content {
            padding: 0 !important;
        }

        .card {
            page-break-inside: avoid;
            border: 1px solid #ddd !important;
        }

        .table {
            font-size: 11pt;
            page-break-inside: avoid;
        }

        .bg-gradient {
            background: white !important;
            border: 2px solid #333 !important;
        }

        .bg-gradient h3 {
            color: #333 !important;
        }

        .bg-gradient p {
            color: #666 !important;
        }

        body {
            margin: 0;
            padding: 0;
        }

        .dashboard-body {
            padding: 0 !important;
        }

        .table thead {
            background-color: #f8f9fa !important;
        }
    }

    .report-metric-card {
        border-radius: 12px;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

    .report-metric-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 8px 16px rgba(0,0,0,0.15) !important;
    }

    .filter-section {
        background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
        border-radius: 12px;
        padding: 20px;
        margin-bottom: 25px;
    }

    .filter-controls {
        display: flex;
        gap: 15px;
        align-items: flex-end;
        flex-wrap: wrap;
    }

    .filter-group {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .filter-group label {
        font-weight: 600;
        font-size: 0.9rem;
        color: #333;
    }

    .filter-group input,
    .filter-group select {
        padding: 10px 12px;
        border: 2px solid #ddd;
        border-radius: 6px;
        font-size: 0.95rem;
        transition: border-color 0.3s ease;
    }

    .filter-group input:focus,
    .filter-group select:focus {
        border-color: #667eea;
        outline: none;
    }

    .btn-group-controls {
        display: flex;
        gap: 10px;
    }

    .print-hide-btn {
        font-size: 0.9rem;
        padding: 8px 16px;
    }

    .report-title {
        font-size: 1.8rem;
        font-weight: 700;
        color: #333;
        margin-bottom: 10px;
    }

    .report-subtitle {
        font-size: 0.95rem;
        color: #666;
        margin-bottom: 25px;
    }

    .payment-comparison {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
        margin-bottom: 30px;
    }

    .payment-card {
        padding: 25px;
        border-radius: 12px;
        color: white;
        text-align: center;
    }

    .payment-card.cod {
        background: linear-gradient(135deg, #f5af19 0%, #f12711 100%);
    }

    .payment-card.transfer {
        background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
    }

    .payment-card h4 {
        font-size: 0.95rem;
        opacity: 0.9;
        margin-bottom: 10px;
        font-weight: 600;
    }

    .payment-card .amount {
        font-size: 2rem;
        font-weight: 700;
    }

    .payment-card .count {
        font-size: 0.85rem;
        opacity: 0.85;
        margin-top: 8px;
    }

    .no-data-message {
        text-align: center;
        padding: 60px 20px;
        color: #999;
    }

    .no-data-message i {
        font-size: 4rem;
        opacity: 0.3;
        display: block;
        margin-bottom: 15px;
    }
</style>

<div class="dashboard-header p-4 bg-white border-bottom shadow-sm rounded-3 mb-4">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h2 class="mb-1 fw-bold">Reports & Analytics</h2>
            <p class="text-muted mb-0">Comprehensive business insights and inventory metrics.</p>
        </div>
        <button class="btn btn-primary d-flex align-items-center gap-2" @onclick="RefreshReports">
            <i class="bi bi-arrow-clockwise"></i> Refresh Reports
        </button>
    </div>
</div>

<div class="dashboard-body px-4">
    @if (isLoading)
    {
        <div class="alert alert-info text-center" role="alert">
            <div class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></div>
            Loading reports...
        </div>
    }
    else
    {
        <!-- Nav Tabs -->
        <div class="card border-0 shadow-sm">
            <div class="card-body p-0">
                <ul class="nav nav-tabs border-bottom" id="reportsTabs" role="tablist">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link @(activeTab == "sales" ? "active" : "")" @onclick='() => SetActiveTab("sales")' type="button" role="tab">
                            <i class="bi bi-graph-up me-2"></i>Sales & Revenue
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link @(activeTab == "inventory" ? "active" : "")" @onclick='() => SetActiveTab("inventory")' type="button" role="tab">
                            <i class="bi bi-box-seam me-2"></i>Inventory & Stock
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link @(activeTab == "fulfillment" ? "active" : "")" @onclick='() => SetActiveTab("fulfillment")' type="button" role="tab">
                            <i class="bi bi-truck me-2"></i>Order Fulfillment
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link @(activeTab == "customers" ? "active" : "")" @onclick='() => SetActiveTab("customers")' type="button" role="tab">
                            <i class="bi bi-people me-2"></i>Customer Insights
                        </button>
                    </li>
                </ul>

                <!-- Tab Content -->
                <div class="tab-content p-4" id="reportsTabContent">
                    <!-- Tab 1: Sales & Revenue (INTERACTIVE) -->
                    @if (activeTab == "sales")
                    {
                        <div class="tab-pane active show">
                        <!-- Filter Section -->
                        <div class="filter-section">
                            <div class="filter-controls">
                                <div class="filter-group" style="flex: 0 1 auto;">
                                    <label for="reportType">Report Type</label>
                                    <select id="reportType" class="form-select" @bind:event="onchange" @bind="selectedReportType">
                                        <option value="daily">📅 Daily Sales</option>
                                        <option value="monthly">📊 Monthly Sales</option>
                                        <option value="top-items">⭐ Top Selling Items</option>
                                        <option value="payment">💳 Payment Summary</option>
                                    </select>
                                </div>

                                @if (selectedReportType == "daily")
                                {
                                    <div class="filter-group" style="flex: 0 1 auto;">
                                        <label for="selectedDate">Select Date</label>
                                        <input type="date" id="selectedDate" class="form-control" value="@filterDate.ToString("yyyy-MM-dd")" @onchange="DateChanged" />
                                    </div>
                                }
                                else if (selectedReportType == "monthly")
                                {
                                    <div class="filter-group" style="flex: 0 1 auto;">
                                        <label for="selectedMonth">Select Month</label>
                                        <input type="month" id="selectedMonth" class="form-control" value="@filterMonthString" @onchange="MonthChanged" />
                                    </div>
                                }

                                <div class="btn-group-controls ms-auto">
                                    <button class="btn btn-primary d-flex align-items-center gap-2 print-hide-btn" @onclick="GenerateReport">
                                        <i class="bi bi-sliders"></i> Generate Report
                                    </button>
                                    <button class="btn btn-success d-flex align-items-center gap-2 print-hide-btn" @onclick="PrintReport">
                                        <i class="bi bi-printer"></i> Print Report
                                    </button>
                                </div>
                            </div>
                        </div>

                        <!-- Daily/Monthly Sales View -->
                        @if (selectedReportType == "daily" || selectedReportType == "monthly")
                        {
                            <div class="report-title">
                                @if (selectedReportType == "daily")
                                {
                                    <span>📅 Daily Sales Report - @filterDate.ToString("MMMM dd, yyyy")</span>
                                }
                                else
                                {
                                    <span>📊 Monthly Sales Report - @GetMonthYearDisplay()</span>
                                }
                            </div>

                            <div class="row mb-4">
                                <div class="col-md-6">
                                    <div class="card border-0 bg-gradient text-white shadow-sm report-metric-card" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                                        <div class="card-body">
                                            <div class="d-flex justify-content-between align-items-center">
                                                <div>
                                                    <p class="text-white-50 mb-0">Total Revenue</p>
                                                    <h3 class="mb-0 fw-bold">Rs. @FormatCurrency(filteredRevenueTotal)</h3>
                                                </div>
                                                <i class="bi bi-graph-up-arrow" style="font-size: 2.5rem; opacity: 0.7;"></i>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="card border-0 bg-gradient text-white shadow-sm report-metric-card" style="background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);">
                                        <div class="card-body">
                                            <div class="d-flex justify-content-between align-items-center">
                                                <div>
                                                    <p class="text-white-50 mb-0">Total Orders</p>
                                                    <h3 class="mb-0 fw-bold">@filteredOrdersList.Count</h3>
                                                </div>
                                                <i class="bi bi-bag-check" style="font-size: 2.5rem; opacity: 0.7;"></i>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Filtered Orders Table -->
                            <div class="card border-0 shadow-sm">
                                <div class="card-header bg-light border-bottom py-3">
                                    <h5 class="mb-0"><i class="bi bi-receipt me-2 text-primary"></i>Order Details</h5>
                                </div>
                                <div class="card-body p-0">
                                    @if (filteredOrdersList.Any())
                                    {
                                        <div class="table-responsive">
                                            <table class="table table-hover align-middle mb-0">
                                                <thead class="bg-light">
                                                    <tr>
                                                        <th class="ps-4">Order ID</th>
                                                        <th>Order Date</th>
                                                        <th>Item</th>
                                                        <th class="text-center">Qty</th>
                                                        <th class="text-end">Amount</th>
                                                        <th class="text-center">Status</th>
                                                        <th class="text-center pe-4">Delivery</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @foreach (var order in filteredOrdersList)
                                                    {
                                                        <tr>
                                                            <td class="ps-4 fw-bold text-primary">@order.OrderId</td>
                                                            <td>@order.OrderDate.ToString("MMM dd, yyyy")</td>
                                                            <td class="small">@order.Item</td>
                                                            <td class="text-center">
                                                                <span class="badge bg-info">@order.Quantity</span>
                                                            </td>
                                                            <td class="text-end fw-semibold">Rs. @FormatCurrency(order.TotalAmount)</td>
                                                            <td class="text-center">
                                                                <span class="badge @GetStatusBadge(order.Status)">@order.Status</span>
                                                            </td>
                                                            <td class="text-center pe-4">
                                                                <span class="badge @GetPaymentBadge(order.DeliveryType)">@order.DeliveryType</span>
                                                            </td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="no-data-message">
                                            <i class="bi bi-inbox"></i>
                                            <p>No orders found for the selected @(selectedReportType == "daily" ? "date" : "month").</p>
                                        </div>
                                    }
                                </div>
                            </div>
                        }

                        <!-- Top Selling Items View -->
                        @if (selectedReportType == "top-items")
                        {
                            <div class="report-title">⭐ Top Selling Items Report</div>
                            <div class="report-subtitle">Ranked by revenue generated</div>

                            <div class="row mb-4">
                                <div class="col-md-4">
                                    <div class="card border-0 bg-gradient text-white shadow-sm report-metric-card" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                                        <div class="card-body">
                                            <p class="text-white-50 mb-0">Total Items Sold</p>
                                            <h3 class="mb-0 fw-bold">@topSellingItems.Sum(x => x.TotalQuantity)</h3>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="card border-0 bg-gradient text-white shadow-sm report-metric-card" style="background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);">
                                        <div class="card-body">
                                            <p class="text-white-50 mb-0">Product Variety</p>
                                            <h3 class="mb-0 fw-bold">@topSellingItems.Count</h3>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="card border-0 bg-gradient text-white shadow-sm report-metric-card" style="background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);">
                                        <div class="card-body">
                                            <p class="text-white-50 mb-0">Revenue Generated</p>
                                            <h3 class="mb-0 fw-bold">Rs. @FormatCurrency(topSellingItems.Sum(x => x.TotalRevenue))</h3>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="card border-0 shadow-sm">
                                <div class="card-header bg-light border-bottom py-3">
                                    <h5 class="mb-0"><i class="bi bi-trophy me-2 text-warning"></i>Top Selling Products</h5>
                                </div>
                                <div class="card-body p-0">
                                    @if (topSellingItems.Any())
                                    {
                                        <div class="table-responsive">
                                            <table class="table table-hover align-middle mb-0">
                                                <thead class="bg-light">
                                                    <tr>
                                                        <th class="ps-4" style="width: 80px;">Rank</th>
                                                        <th>Product Name</th>
                                                        <th class="text-center">Quantity Sold</th>
                                                        <th class="text-end">Revenue</th>
                                                        <th class="text-center pe-4">% of Sales</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @{
                                                        int itemRank = 1;
                                                        foreach (var item in topSellingItems.OrderByDescending(x => x.TotalRevenue))
                                                        {
                                                            <tr>
                                                                <td class="ps-4">
                                                                    @if (itemRank == 1)
                                                                    {
                                                                        <span class="badge bg-warning text-dark fw-bold" style="font-size: 1rem;">🥇 #@itemRank</span>
                                                                    }
                                                                    else if (itemRank == 2)
                                                                    {
                                                                        <span class="badge bg-secondary fw-bold" style="font-size: 1rem;">🥈 #@itemRank</span>
                                                                    }
                                                                    else if (itemRank == 3)
                                                                    {
                                                                        <span class="badge fw-bold" style="background-color: #CD7F32; font-size: 1rem;">🥉 #@itemRank</span>
                                                                    }
                                                                    else
                                                                    {
                                                                        <span class="badge bg-light text-dark fw-bold" style="font-size: 1rem;">#@itemRank</span>
                                                                    }
                                                                </td>
                                                                <td class="fw-semibold">@item.ItemName</td>
                                                                <td class="text-center">
                                                                    <span class="badge bg-info">@item.TotalQuantity units</span>
                                                                </td>
                                                                <td class="text-end fw-semibold">Rs. @FormatCurrency(item.TotalRevenue)</td>
                                                                <td class="text-center pe-4">
                                                                    <div style="background: linear-gradient(90deg, #667eea 0%, #667eea @(item.SalesPercentage)%, #eee @(item.SalesPercentage)%, #eee 100%); padding: 4px 8px; border-radius: 4px; font-weight: 600; color: white; font-size: 0.9rem;">
                                                                        @item.SalesPercentage%
                                                                    </div>
                                                                </td>
                                                            </tr>
                                                            itemRank++;
                                                        }
                                                    }
                                                </tbody>
                                            </table>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="no-data-message">
                                            <i class="bi bi-inbox"></i>
                                            <p>No sales data available yet.</p>
                                        </div>
                                    }
                                </div>
                            </div>
                        }

                        <!-- Payment Summary View -->
                        @if (selectedReportType == "payment")
                        {
                            <div class="report-title">💳 Payment Method Summary</div>
                            <div class="report-subtitle">Comparison of payment methods and revenue</div>

                            <div class="payment-comparison">
                                @{
                                    var codTotal = revenueByPaymentMethod.FirstOrDefault(x => x.DeliveryType == "COD");
                                    var transferTotal = revenueByPaymentMethod.FirstOrDefault(x => x.DeliveryType == "Online Transfer");
                                }

                                <div class="payment-card cod">
                                    <h4>💵 Cash on Delivery (COD)</h4>
                                    <div class="amount">Rs. @FormatCurrency(codTotal?.TotalAmount ?? 0)</div>
                                    <div class="count">@(codTotal?.OrderCount ?? 0) orders</div>
                                </div>

                                <div class="payment-card transfer">
                                    <h4>🏦 Online Transfer</h4>
                                    <div class="amount">Rs. @FormatCurrency(transferTotal?.TotalAmount ?? 0)</div>
                                    <div class="count">@(transferTotal?.OrderCount ?? 0) orders</div>
                                </div>
                            </div>

                            <div class="card border-0 shadow-sm">
                                <div class="card-header bg-light border-bottom py-3">
                                    <h5 class="mb-0"><i class="bi bi-table me-2 text-primary"></i>Detailed Breakdown</h5>
                                </div>
                                <div class="card-body p-0">
                                    @if (revenueByPaymentMethod.Any())
                                    {
                                        <div class="table-responsive">
                                            <table class="table table-hover align-middle mb-0">
                                                <thead class="bg-light">
                                                    <tr>
                                                        <th class="ps-4">Payment Method</th>
                                                        <th class="text-center">Number of Orders</th>
                                                        <th class="text-end">Total Amount</th>
                                                        <th class="text-end">Average Order Value</th>
                                                        <th class="text-center pe-4">% of Total Revenue</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @{
                                                        decimal totalPaymentRevenue = revenueByPaymentMethod.Sum(x => x.TotalAmount);
                                                        foreach (var payment in revenueByPaymentMethod.OrderByDescending(x => x.TotalAmount))
                                                        {
                                                            <tr>
                                                                <td class="ps-4">
                                                                    @if (payment.DeliveryType == "COD")
                                                                    {
                                                                        <span class="badge bg-warning-subtle text-warning border border-warning">💵 @payment.DeliveryType</span>
                                                                    }
                                                                    else
                                                                    {
                                                                        <span class="badge bg-success-subtle text-success border border-success">🏦 @payment.DeliveryType</span>
                                                                    }
                                                                </td>
                                                                <td class="text-center fw-semibold">@payment.OrderCount</td>
                                                                <td class="text-end fw-semibold">Rs. @FormatCurrency(payment.TotalAmount)</td>
                                                                <td class="text-end">Rs. @FormatCurrency(payment.AverageOrderValue)</td>
                                                                <td class="text-center pe-4">
                                                                    <span class="badge bg-primary">@(totalPaymentRevenue > 0 ? (int)((payment.TotalAmount / totalPaymentRevenue) * 100) : 0)%</span>
                                                                </td>
                                                            </tr>
                                                        }
                                                    }
                                                </tbody>
                                            </table>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="no-data-message">
                                            <i class="bi bi-inbox"></i>
                                            <p>No payment method data available.</p>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                    }

                    <!-- Tab 2: Inventory & Stock -->
                    @if (activeTab == "inventory")
                    {
                        <div class="tab-pane active show">
                        <!-- Filter Section -->
                        <div class="filter-section">
                            <div class="filter-controls">
                                <div class="filter-group">
                                    <label><i class="bi bi-funnel me-2"></i>Stock Report Type</label>
                                    <select class="form-select" @onchange="StockReportTypeChanged">
                                        <option value="low-out-of-stock">Low/Out of Stock</option>
                                        <option value="slow-moving">Slow-Moving/Dead Stock</option>
                                        <option value="inventory-value">Inventory Value</option>
                                    </select>
                                </div>

                                @if (selectedStockReportType == "slow-moving")
                                {
                                    <div class="filter-group">
                                        <label><i class="bi bi-calendar me-2"></i>Items Not Sold Since</label>
                                        <input type="date" class="form-control" @onchange="SlowMovingDateChanged" 
                                               value="@slowMovingCutoffDate.ToString("yyyy-MM-dd")" />
                                    </div>
                                }

                                <div class="filter-group" style="margin-top: auto;">
                                    <button class="btn btn-primary" @onclick="GenerateInventoryReport">
                                        <i class="bi bi-arrow-clockwise me-2"></i>Generate
                                    </button>
                                    <button class="btn btn-secondary print-hide-btn ms-2" @onclick="PrintReport">
                                        <i class="bi bi-printer me-2"></i>Print Report
                                    </button>
                                </div>
                            </div>
                        </div>

                        <!-- Low/Out of Stock View -->
                        @if (selectedStockReportType == "low-out-of-stock")
                        {
                            <div class="card border-0 shadow-sm">
                                <div class="card-header bg-light border-bottom py-3">
                                    <h5 class="mb-0"><i class="bi bi-exclamation-triangle me-2 text-warning"></i>Low & Out of Stock Products</h5>
                                </div>
                                <div class="card-body p-0">
                                    @if (filteredLowStockProducts.Any())
                                    {
                                        <div class="table-responsive">
                                            <table class="table table-hover align-middle mb-0">
                                                <thead class="bg-light">
                                                    <tr>
                                                        <th class="ps-4">Product Name</th>
                                                        <th class="text-center">Current Stock</th>
                                                        <th class="text-center">Status</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @foreach (var product in filteredLowStockProducts)
                                                    {
                                                        <tr style="@(product.StockQuantity == 0 ? "background-color: #ffcccc;" : product.StockQuantity <= product.LowStockLevel ? "background-color: #ffffcc;" : "")">
                                                            <td class="ps-4 fw-semibold">@product.Name</td>
                                                            <td class="text-center">
                                                                <span class="badge @(product.StockQuantity == 0 ? "bg-danger" : "bg-warning text-dark")">
                                                                    @product.StockQuantity units
                                                                </span>
                                                            </td>
                                                            <td class="text-center">
                                                                @if (product.StockQuantity == 0)
                                                                {
                                                                    <span class="badge bg-danger">Out of Stock</span>
                                                                }
                                                                else
                                                                {
                                                                    <span class="badge bg-warning text-dark">Low Stock</span>
                                                                }
                                                            </td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="no-data-message">
                                            <i class="bi bi-check-circle"></i>
                                            <p>All products are in stock!</p>
                                        </div>
                                    }
                                </div>
                            </div>
                        }

                        <!-- Slow-Moving/Dead Stock View -->
                        @if (selectedStockReportType == "slow-moving")
                        {
                            <div class="card border-0 shadow-sm">
                                <div class="card-header bg-light border-bottom py-3">
                                    <h5 class="mb-0"><i class="bi bi-clock-history me-2 text-info"></i>Slow-Moving / Dead Stock Products</h5>
                                </div>
                                <div class="card-body p-0">
                                    @if (filteredSlowMovingProducts.Any())
                                    {
                                        <div class="table-responsive">
                                            <table class="table table-hover align-middle mb-0">
                                                <thead class="bg-light">
                                                    <tr>
                                                        <th class="ps-4">Product Name</th>
                                                        <th class="text-center">Current Stock</th>
                                                        <th class="text-center">Last Sold Date</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @foreach (var product in filteredSlowMovingProducts)
                                                    {
                                                        <tr>
                                                            <td class="ps-4 fw-semibold">@product.ProductName</td>
                                                            <td class="text-center">
                                                                <span class="badge bg-info">@product.StockQuantity units</span>
                                                            </td>
                                                            <td class="text-center">
                                                                @if (product.LastSoldDate.HasValue)
                                                                {
                                                                    <span>@product.LastSoldDate.Value.ToString("MMM dd, yyyy")</span>
                                                                }
                                                                else
                                                                {
                                                                    <span class="badge bg-danger">Never Sold</span>
                                                                }
                                                            </td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="no-data-message">
                                            <i class="bi bi-inbox"></i>
                                            <p>No slow-moving products found for the selected date.</p>
                                        </div>
                                    }
                                </div>
                            </div>
                        }

                        <!-- Inventory Value View -->
                        @if (selectedStockReportType == "inventory-value")
                        {
                            <div class="row mb-4">
                                <div class="col-md-6">
                                    <div class="card border-0 bg-gradient text-white shadow-sm" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                                        <div class="card-body">
                                            <div class="d-flex justify-content-between align-items-center">
                                                <div>
                                                    <p class="text-white-50 mb-0">Total Items in Stock</p>
                                                    <h3 class="mb-0 fw-bold">@totalUnitsInStock</h3>
                                                    <small class="text-white-50">units</small>
                                                </div>
                                                <i class="bi bi-stack" style="font-size: 2.5rem; opacity: 0.7;"></i>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="card border-0 bg-gradient text-white shadow-sm" style="background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);">
                                        <div class="card-body">
                                            <div class="d-flex justify-content-between align-items-center">
                                                <div>
                                                    <p class="text-white-50 mb-0">Total Inventory Capital</p>
                                                    <h3 class="mb-0 fw-bold">Rs. @FormatCurrency(totalInventoryValue)</h3>
                                                </div>
                                                <i class="bi bi-currency-rupee" style="font-size: 2.5rem; opacity: 0.7;"></i>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="card border-0 shadow-sm">
                                <div class="card-header bg-light border-bottom py-3">
                                    <h5 class="mb-0"><i class="bi bi-table me-2 text-success"></i>Inventory Value Breakdown by Product</h5>
                                </div>
                                <div class="card-body p-0">
                                    @if (inventoryValueBreakdown.Any())
                                    {
                                        <div class="table-responsive">
                                            <table class="table table-hover align-middle mb-0">
                                                <thead class="bg-light">
                                                    <tr>
                                                        <th class="ps-4">Product Name</th>
                                                        <th class="text-center">Current Stock</th>
                                                        <th class="text-end">Unit Price</th>
                                                        <th class="text-end pe-4">Total Value (Rs.)</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @foreach (var item in inventoryValueBreakdown)
                                                    {
                                                        <tr>
                                                            <td class="ps-4 fw-semibold">@item.ProductName</td>
                                                            <td class="text-center">
                                                                <span class="badge bg-primary">@item.StockQuantity units</span>
                                                            </td>
                                                            <td class="text-end">Rs. @FormatCurrency(item.Price)</td>
                                                            <td class="text-end fw-bold pe-4 text-success">
                                                                Rs. @FormatCurrency(item.TotalValue)
                                                            </td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="no-data-message">
                                            <i class="bi bi-inbox"></i>
                                            <p>No inventory data available.</p>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                    }

                    <!-- Tab 3: Order Fulfillment -->
                    @if (activeTab == "fulfillment")
                    {
                        <div class="tab-pane active show">
                        <!-- Filter Section -->
                        <div class="filter-section">
                            <div class="filter-controls">
                                <div class="filter-group">
                                    <label><i class="bi bi-funnel me-2"></i>Order Status View</label>
                                    <select class="form-select" @onchange="FulfillmentStatusChanged">
                                        <option value="Processing">Processing (Pending Dispatches)</option>
                                        <option value="Completed">Completed Orders</option>
                                        <option value="Cancelled">Cancelled Orders</option>
                                    </select>
                                </div>

                                <div class="filter-group" style="margin-top: auto;">
                                    <button class="btn btn-primary" @onclick="GenerateFulfillmentReport">
                                        <i class="bi bi-arrow-clockwise me-2"></i>Generate
                                    </button>
                                    <button class="btn btn-secondary print-hide-btn ms-2" @onclick="PrintReport">
                                        <i class="bi bi-printer me-2"></i>Print Report
                                    </button>
                                </div>
                            </div>
                        </div>

                        <!-- Courier Team Alert (Only for Processing status) -->
                        @if (selectedFulfillmentStatus == "Processing")
                        {
                            <div class="mb-4">
                                <div class="alert alert-info border-0 shadow-sm d-flex align-items-center gap-3" role="alert">
                                    <i class="bi bi-info-circle" style="font-size: 1.5rem;"></i>
                                    <div>
                                        <strong>Courier Team View:</strong> This table shows all pending orders (Status: Processing) that need to be dispatched.
                                    </div>
                                </div>
                            </div>
                        }

                        <!-- Order Fulfillment Table -->
                        <div class="card border-0 shadow-sm">
                            <div class="card-header bg-light border-bottom py-3 d-flex justify-content-between align-items-center">
                                <h5 class="mb-0">
                                    @if (selectedFulfillmentStatus == "Processing")
                                    {
                                        <i class="bi bi-hourglass-split me-2 text-warning"></i><span>Pending Dispatches</span>
                                    }
                                    else if (selectedFulfillmentStatus == "Completed")
                                    {
                                        <i class="bi bi-check-circle me-2 text-success"></i><span>Completed Orders</span>
                                    }
                                    else if (selectedFulfillmentStatus == "Cancelled")
                                    {
                                        <i class="bi bi-x-circle me-2 text-danger"></i><span>Cancelled Orders</span>
                                    }
                                </h5>
                                <span class="badge @GetStatusBadgeColor(selectedFulfillmentStatus)">
                                    @filteredFulfillmentOrders.Count @(filteredFulfillmentOrders.Count == 1 ? "order" : "orders")
                                </span>
                            </div>
                            <div class="card-body p-0">
                                @if (filteredFulfillmentOrders.Any())
                                {
                                    <div class="table-responsive">
                                        <table class="table table-hover align-middle mb-0">
                                            <thead class="bg-light">
                                                <tr>
                                                    <th class="ps-4">Order ID</th>
                                                    <th>Customer Name</th>
                                                    <th>Address</th>
                                                    <th>Phone</th>
                                                    <th>Item</th>
                                                    <th class="text-center">Quantity</th>
                                                    <th class="text-end">Total Amount</th>
                                                    <th class="text-center pe-4">Status</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var order in filteredFulfillmentOrders)
                                                {
                                                    <tr>
                                                        <td class="ps-4 fw-bold text-primary">@order.OrderId</td>
                                                        <td>@order.CustomerName</td>
                                                        <td class="small text-muted">@order.Address</td>
                                                        <td class="small">@order.Phone1</td>
                                                        <td class="small">@order.Item</td>
                                                        <td class="text-center">
                                                            <span class="badge bg-info">@order.Quantity</span>
                                                        </td>
                                                        <td class="text-end fw-semibold">Rs. @FormatCurrency(order.TotalAmount)</td>
                                                        <td class="text-center pe-4">
                                                            <span class="badge @GetOrderStatusBadge(order.Status)">
                                                                @order.Status
                                                            </span>
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                }
                                else
                                {
                                    <div class="no-data-message">
                                        @if (selectedFulfillmentStatus == "Processing")
                                        {
                                            <i class="bi bi-check-circle"></i>
                                            <p>No pending orders! All orders have been dispatched.</p>
                                        }
                                        else if (selectedFulfillmentStatus == "Completed")
                                        {
                                            <i class="bi bi-inbox"></i>
                                            <p>No completed orders yet.</p>
                                        }
                                        else if (selectedFulfillmentStatus == "Cancelled")
                                        {
                                            <i class="bi bi-inbox"></i>
                                            <p>No cancelled orders.</p>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                    }

                    <!-- Tab 4: Customer Insights -->
                    @if (activeTab == "customers")
                    {
                        <div class="tab-pane active show">
                        <div class="row mb-4">
                            <div class="col-md-6">
                                <div class="card border-0 bg-gradient text-white shadow-sm" style="background: linear-gradient(135deg, #a8edea 0%, #fed6e3 100%);">
                                    <div class="card-body">
                                        <div class="d-flex justify-content-between align-items-center">
                                            <div>
                                                <p class="text-white-50 mb-0">Total Unique Customers</p>
                                                <h3 class="mb-0 fw-bold" style="color: #333;">@uniqueCustomersCount</h3>
                                            </div>
                                            <i class="bi bi-people" style="font-size: 2rem; opacity: 0.7; color: #333;"></i>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="card border-0 bg-gradient text-white shadow-sm" style="background: linear-gradient(135deg, #ff9a56 0%, #ff6a88 100%);">
                                    <div class="card-body">
                                        <div class="d-flex justify-content-between align-items-center">
                                            <div>
                                                <p class="text-white-50 mb-0">Average Customer Spend</p>
                                                <h3 class="mb-0 fw-bold">Rs. @FormatCurrency(averageCustomerSpend)</h3>
                                            </div>
                                            <i class="bi bi-wallet2" style="font-size: 2rem; opacity: 0.7;"></i>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Top Customers -->
                        <div class="card border-0 shadow-sm">
                            <div class="card-header bg-light border-bottom py-3">
                                <h5 class="mb-0"><i class="bi bi-award me-2 text-primary"></i>Top Customers by Spending</h5>
                            </div>
                            <div class="card-body p-0">
                                @if (topCustomers.Any())
                                {
                                    <div class="table-responsive">
                                        <table class="table table-hover align-middle mb-0">
                                            <thead class="bg-light">
                                                <tr>
                                                    <th class="ps-4">Rank</th>
                                                    <th>Customer Name</th>
                                                    <th class="text-center">Total Orders</th>
                                                    <th class="text-end">Total Spent</th>
                                                    <th class="text-center pe-4">Average Order Value</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @{
                                                    int rank = 1;
                                                    foreach (var customer in topCustomers)
                                                    {
                                                        <tr>
                                                            <td class="ps-4">
                                                                @if (rank == 1)
                                                                {
                                                                    <span class="badge bg-warning text-dark fw-bold">🥇 @rank</span>
                                                                }
                                                                else if (rank == 2)
                                                                {
                                                                    <span class="badge bg-secondary fw-bold">🥈 @rank</span>
                                                                }
                                                                else if (rank == 3)
                                                                {
                                                                    <span class="badge" style="background-color: #CD7F32;">🥉 @rank</span>
                                                                }
                                                                else
                                                                {
                                                                    <span class="badge bg-light text-dark">@rank</span>
                                                                }
                                                            </td>
                                                            <td class="fw-semibold">@customer.CustomerName</td>
                                                            <td class="text-center">
                                                                <span class="badge bg-info">@customer.TotalOrders</span>
                                                            </td>
                                                            <td class="text-end fw-semibold">Rs. @FormatCurrency(customer.TotalSpent)</td>
                                                            <td class="text-center pe-4">
                                                                Rs. @FormatCurrency(customer.AverageOrderValue)
                                                            </td>
                                                        </tr>
                                                        rank++;
                                                    }
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                }
                                else
                                {
                                    <div class="no-data-message">
                                        <i class="bi bi-inbox"></i>
                                        <p>No customer data available yet.</p>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                    }
                </div>
            </div>
        </div>
    }
</div>

@code {
    // Tab navigation state
    private string activeTab = "sales";

    private void SetActiveTab(string tabName)
    {
        activeTab = tabName;
        StateHasChanged();
    }

    // Loading state
    private bool isLoading = true;

    // Tab 1: Sales & Revenue - Filter Data
    private string selectedReportType = "daily";
    private DateTime filterDate = DateTime.Today;
    private string filterMonthString = $"{DateTime.Now.Year}-{DateTime.Now.Month:D2}";
    private List<Order> filteredOrdersList = new();
    private decimal filteredRevenueTotal = 0;

    // Tab 1: Sales & Revenue Data
    private decimal totalRevenue = 0;
    private int totalOrdersCount = 0;
    private List<TopSellingItemDto> topSellingItems = new();
    private List<RevenueByPaymentMethodDto> revenueByPaymentMethod = new();

    // Tab 2: Inventory & Stock Data
    private decimal totalInventoryValue = 0;
    private int totalUnitsInStock = 0;
    private List<Product> lowOutOfStockProducts = new();

    // Tab 2: Inventory & Stock - Filter Data
    private string selectedStockReportType = "low-out-of-stock";
    private DateTime slowMovingCutoffDate = DateTime.Today.AddMonths(-3); // Default: 3 months ago
    private List<Product> filteredLowStockProducts = new();
    private List<SlowMovingProductDto> filteredSlowMovingProducts = new();
    private List<InventoryValueDto> inventoryValueBreakdown = new();

    // Tab 3: Order Fulfillment Data
    private List<Order> pendingOrders = new();

    // Tab 3: Order Fulfillment - Filter Data
    private string selectedFulfillmentStatus = "Processing";
    private List<Order> filteredFulfillmentOrders = new();

    // Tab 4: Customer Insights Data
    private int uniqueCustomersCount = 0;
    private decimal averageCustomerSpend = 0;
    private List<TopCustomerDto> topCustomers = new();

    protected override async Task OnInitializedAsync()
    {
        isLoading = true;
        try
        {
            await LoadAllReports();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading reports: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task LoadAllReports()
    {
        await LoadSalesRevenueData();
        await LoadInventoryStockData();
        await LoadOrderFulfillmentData();
        await LoadCustomerInsightsData();
        await GenerateReport();
    }

    private async Task GenerateReport()
    {
        try
        {
            if (selectedReportType == "daily")
            {
                await LoadDailySalesReport();
            }
            else if (selectedReportType == "monthly")
            {
                await LoadMonthlySalesReport();
            }
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error generating report: {ex.Message}");
        }
    }

    private async Task DateChanged(ChangeEventArgs e)
    {
        if (e.Value != null && DateTime.TryParse(e.Value.ToString(), out DateTime date))
        {
            filterDate = date;
            await GenerateReport();
        }
    }

    private async Task MonthChanged(ChangeEventArgs e)
    {
        if (e.Value != null)
        {
            filterMonthString = e.Value.ToString() ?? filterMonthString;
            await GenerateReport();
        }
    }

    private async Task LoadDailySalesReport()
    {
        try
        {
            filteredOrdersList = await DbContext.Orders
                .Where(o => (o.Status == "Completed" || o.Status == "Processing") && o.OrderDate.Date == filterDate.Date)
                .OrderBy(o => o.OrderDate)
                .ToListAsync();
            filteredRevenueTotal = filteredOrdersList.Sum(o => o.TotalAmount);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading daily sales: {ex.Message}");
        }
    }

    private async Task LoadMonthlySalesReport()
    {
        try
        {
            var monthParts = filterMonthString.Split('-');
            int year = int.Parse(monthParts[0]);
            int month = int.Parse(monthParts[1]);

            filteredOrdersList = await DbContext.Orders
                .Where(o => (o.Status == "Completed" || o.Status == "Processing") 
                    && o.OrderDate.Year == year 
                    && o.OrderDate.Month == month)
                .OrderBy(o => o.OrderDate)
                .ToListAsync();
            filteredRevenueTotal = filteredOrdersList.Sum(o => o.TotalAmount);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading monthly sales: {ex.Message}");
        }
    }

    private string GetMonthYearDisplay()
    {
        try
        {
            var monthParts = filterMonthString.Split('-');
            int year = int.Parse(monthParts[0]);
            int month = int.Parse(monthParts[1]);
            return new DateTime(year, month, 1).ToString("MMMM yyyy");
        }
        catch
        {
            return DateTime.Now.ToString("MMMM yyyy");
        }
    }

    private async Task PrintReport()
    {
        try
        {
            await JS.InvokeVoidAsync("window.print");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error printing report: {ex.Message}");
        }
    }

    private async Task LoadSalesRevenueData()
    {
        try
        {
            totalRevenue = await DbContext.Orders
                .Where(o => o.Status == "Completed" || o.Status == "Processing")
                .SumAsync(o => o.TotalAmount);

            totalOrdersCount = await DbContext.Orders
                .Where(o => o.Status == "Completed" || o.Status == "Processing")
                .CountAsync();

            var topSellingQuery = await DbContext.Orders
                .Where(o => o.Status == "Completed" || o.Status == "Processing")
                .GroupBy(o => o.Item)
                .Select(g => new { ItemName = g.Key, TotalQuantity = g.Sum(o => o.Quantity), TotalRevenue = g.Sum(o => o.TotalAmount) })
                .OrderByDescending(x => x.TotalRevenue)
                .ToListAsync();

            decimal totalSalesRevenue = topSellingQuery.Sum(x => x.TotalRevenue);
            topSellingItems = topSellingQuery
                .Select(x => new TopSellingItemDto
                {
                    ItemName = x.ItemName,
                    TotalQuantity = x.TotalQuantity,
                    TotalRevenue = x.TotalRevenue,
                    SalesPercentage = totalSalesRevenue > 0 ? (int)((x.TotalRevenue / totalSalesRevenue) * 100) : 0
                })
                .ToList();

            revenueByPaymentMethod = await DbContext.Orders
                .Where(o => o.Status == "Completed" || o.Status == "Processing")
                .GroupBy(o => o.DeliveryType)
                .Select(g => new RevenueByPaymentMethodDto
                {
                    DeliveryType = g.Key,
                    OrderCount = g.Count(),
                    TotalAmount = g.Sum(o => o.TotalAmount),
                    AverageOrderValue = g.Average(o => o.TotalAmount)
                })
                .OrderByDescending(x => x.TotalAmount)
                .ToListAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading sales revenue data: {ex.Message}");
        }
    }

    private async Task LoadInventoryStockData()
    {
        try
        {
            totalInventoryValue = await DbContext.Products.SumAsync(p => p.StockQuantity * p.Price);
            totalUnitsInStock = await DbContext.Products.SumAsync(p => p.StockQuantity);
            lowOutOfStockProducts = await DbContext.Products
                .Where(p => p.StockQuantity <= p.LowStockLevel)
                .OrderBy(p => p.StockQuantity)
                .ToListAsync();

            // Initialize filtered lists with default view (Low/Out of Stock)
            await GenerateInventoryReport();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading inventory data: {ex.Message}");
        }
    }

    private async Task StockReportTypeChanged(ChangeEventArgs e)
    {
        if (e.Value != null)
        {
            selectedStockReportType = e.Value.ToString() ?? "low-out-of-stock";
            await GenerateInventoryReport();
        }
    }

    private async Task SlowMovingDateChanged(ChangeEventArgs e)
    {
        if (e.Value != null && DateTime.TryParse(e.Value.ToString(), out DateTime date))
        {
            slowMovingCutoffDate = date;
            await GenerateInventoryReport();
        }
    }

    private async Task GenerateInventoryReport()
    {
        try
        {
            if (selectedStockReportType == "low-out-of-stock")
            {
                await LoadLowOutOfStockData();
            }
            else if (selectedStockReportType == "slow-moving")
            {
                await LoadSlowMovingData();
            }
            else if (selectedStockReportType == "inventory-value")
            {
                await LoadInventoryValueData();
            }
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error generating inventory report: {ex.Message}");
        }
    }

    private async Task LoadLowOutOfStockData()
    {
        try
        {
            filteredLowStockProducts = await DbContext.Products
                .Where(p => p.StockQuantity <= p.LowStockLevel)
                .OrderBy(p => p.StockQuantity)
                .ToListAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading low/out of stock data: {ex.Message}");
        }
    }

    private async Task LoadSlowMovingData()
    {
        try
        {
            // Alternative simpler approach: Get products and find those never ordered or ordered before cutoff date
            var allProducts = await DbContext.Products.ToListAsync();

            filteredSlowMovingProducts = new();

            foreach (var product in allProducts)
            {
                // Check if product was ever ordered
                var lastOrderDate = await DbContext.Orders
                    .Where(o => o.Item == product.Name)
                    .OrderByDescending(o => o.OrderDate)
                    .Select(o => (DateTime?)o.OrderDate)
                    .FirstOrDefaultAsync();

                // If never ordered, or last order is before cutoff date, include it
                if (lastOrderDate == null || lastOrderDate.Value < slowMovingCutoffDate)
                {
                    filteredSlowMovingProducts.Add(new SlowMovingProductDto
                    {
                        ProductName = product.Name,
                        StockQuantity = product.StockQuantity,
                        LastSoldDate = lastOrderDate
                    });
                }
            }

            filteredSlowMovingProducts = filteredSlowMovingProducts.OrderBy(p => p.LastSoldDate).ToList();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading slow-moving data: {ex.Message}");
            filteredSlowMovingProducts = new();
        }
    }

    private async Task LoadInventoryValueData()
    {
        try
        {
            inventoryValueBreakdown = await DbContext.Products
                .Where(p => p.StockQuantity > 0)
                .Select(p => new InventoryValueDto
                {
                    ProductName = p.Name,
                    StockQuantity = p.StockQuantity,
                    Price = p.Price,
                    TotalValue = p.StockQuantity * p.Price
                })
                .OrderByDescending(p => p.TotalValue)
                .ToListAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading inventory value data: {ex.Message}");
        }
    }

    private async Task LoadOrderFulfillmentData()
    {
        try
        {
            pendingOrders = await DbContext.Orders
                .Where(o => o.Status == "Processing")
                .OrderBy(o => o.OrderDate)
                .ToListAsync();

            // Initialize filtered list with default view (Processing)
            await GenerateFulfillmentReport();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading order fulfillment data: {ex.Message}");
        }
    }

    private async Task FulfillmentStatusChanged(ChangeEventArgs e)
    {
        if (e.Value != null)
        {
            selectedFulfillmentStatus = e.Value.ToString() ?? "Processing";
            await GenerateFulfillmentReport();
        }
    }

    private async Task GenerateFulfillmentReport()
    {
        try
        {
            filteredFulfillmentOrders = await DbContext.Orders
                .Where(o => o.Status == selectedFulfillmentStatus)
                .OrderByDescending(o => o.OrderDate)
                .ToListAsync();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error generating fulfillment report: {ex.Message}");
        }
    }

    private string GetStatusBadgeColor(string status) => status switch
    {
        "Processing" => "bg-warning",
        "Completed" => "bg-success",
        "Cancelled" => "bg-danger",
        _ => "bg-secondary"
    };

    private string GetOrderStatusBadge(string status) => status switch
    {
        "Completed" => "bg-success-subtle text-success border border-success",
        "Processing" => "bg-warning-subtle text-warning-emphasis border border-warning",
        "Cancelled" => "bg-danger-subtle text-danger border border-danger",
        _ => "bg-secondary-subtle text-secondary border border-secondary"
    };

    private async Task LoadCustomerInsightsData()
    {
        try
        {
            uniqueCustomersCount = await DbContext.Orders.Select(o => o.CustomerName).Distinct().CountAsync();

            var topCustomersQuery = await DbContext.Orders
                .GroupBy(o => o.CustomerName)
                .Select(g => new { CustomerName = g.Key, TotalOrders = g.Count(), TotalSpent = g.Sum(o => o.TotalAmount) })
                .OrderByDescending(x => x.TotalSpent)
                .Take(10)
                .ToListAsync();

            topCustomers = topCustomersQuery
                .Select(x => new TopCustomerDto
                {
                    CustomerName = x.CustomerName,
                    TotalOrders = x.TotalOrders,
                    TotalSpent = x.TotalSpent,
                    AverageOrderValue = x.TotalOrders > 0 ? x.TotalSpent / x.TotalOrders : 0
                })
                .ToList();

            averageCustomerSpend = uniqueCustomersCount > 0
                ? await DbContext.Orders.SumAsync(o => o.TotalAmount) / uniqueCustomersCount
                : 0;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading customer insights data: {ex.Message}");
        }
    }

    private async Task RefreshReports()
    {
        isLoading = true;
        StateHasChanged();
        await Task.Delay(500);
        await LoadAllReports();
        isLoading = false;
        StateHasChanged();
    }

